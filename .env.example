# =============================================================================
# ENVIRONMENT VARIABLES - Nail Salon SaaS
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# Core App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=
# Root domain used for wildcard tenant links (for example: luster.com)
LUSTER_ROOT_DOMAIN=luster.com
NEXT_PUBLIC_LUSTER_BUILDER_GEL_EDUCATION_URL=https://luster.com/pages/builder-gel-education
NEXT_PUBLIC_LUSTER_TECHNIQUE_GUIDES_URL=https://luster.com/pages/education
NEXT_PUBLIC_LUSTER_BUILDER_GEL_SHOP_URL=https://luster.com/collections/builder-gel
# 32+ random characters. Rotate by incrementing the key version after a migration.
INTEGRATION_ENCRYPTION_KEY=
INTEGRATION_ENCRYPTION_KEY_VERSION=1
OAUTH_STATE_SECRET=

# -----------------------------------------------------------------------------
# Twilio (OTP Auth + SMS Notifications)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_PHONE_NUMBER=
# Twilio Connect app used for salon-funded subaccounts
TWILIO_CONNECT_APP_SID=
TWILIO_CONNECT_REDIRECT_URI=https://app.luster.com/api/integrations/twilio/callback

# -----------------------------------------------------------------------------
# Per-salon Google Calendar OAuth
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://app.luster.com/api/integrations/google/callback

# -----------------------------------------------------------------------------
# Stripe (Salon Subscription Billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Meta Graph API (Instagram/Facebook Auto-posting)
# -----------------------------------------------------------------------------
# Get these from Meta Business Suite / Developer Portal
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=
META_FACEBOOK_PAGE_ID=
META_INSTAGRAM_ACCOUNT_ID=
META_GRAPH_VERSION=v19.0

# -----------------------------------------------------------------------------
# Cloudinary (Image Storage)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Sentry (Error Monitoring)
# -----------------------------------------------------------------------------
# Local/dev can omit all Sentry vars.
# Under the current strict build guard, Vercel Production and Preview both require the four vars below.
# Recommended: use a separate Preview project/DSN so preview issues and releases stay isolated from Production.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Optional production overrides
# If unset, release falls back in this order:
# 1. SENTRY_RELEASE
# 2. VERCEL_GIT_COMMIT_SHA
# 3. GITHUB_SHA
# 4. package.json version
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=

# -----------------------------------------------------------------------------
# Resend (Transactional Booking Emails)
# -----------------------------------------------------------------------------
# Optional in local/dev. Required only if you want owner/technician email booking notifications.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Optional custom reply-to for booking alert emails
RESEND_REPLY_TO_EMAIL=

# -----------------------------------------------------------------------------
# Cron Worker Authentication
# -----------------------------------------------------------------------------
# Secret for authenticating cron job requests (e.g., autopost worker)
CRON_SECRET=

# -----------------------------------------------------------------------------
# Redis (Rate Limiting, Idempotency, Presign Replay Protection)
# -----------------------------------------------------------------------------
# Use rediss:// for TLS connections (most providers require this)
REDIS_URL=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=
